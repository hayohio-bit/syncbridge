# SyncBridge Backend 환경변수 템플릿
# 이 파일을 복사하여 .env 를 만드세요: cp .env.template .env
#
# [dev 프로파일] H2 인메모리 DB 사용 시 JWT_SECRET만 설정하면 됩니다.
# [local-mysql / prod 프로파일] DB 관련 변수도 설정해야 합니다.

# ── JWT 설정 (필수) ─────────────────────────────────────────────
JWT_SECRET=your-secret-key-must-be-at-least-256-bits-long-change-this

# ── DB 설정 (local-mysql / prod 프로파일 사용 시) ──────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=syncbridge
DB_USERNAME=sbuser
DB_PASSWORD=3306
