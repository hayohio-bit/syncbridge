# ──────────────────────────────────────────────────
# SyncBridge Environment Variables Template
# 프로젝트 루트에 .env 이름으로 복사하여 사용하세요.
# ──────────────────────────────────────────────────

# [1] Database Settings (MySQL/Docker)
DB_HOST=localhost
DB_PORT=3306
DB_ROOT_PASSWORD=root1234
DB_NAME=syncbridge
DB_USERNAME=sbuser
DB_PASSWORD=3306

# [2] Security Settings (JWT)
# 운영(Production) 환경에서는 브루트포스를 막기 위해 256비트 이상의 강력한 비밀키를 사용해야 합니다.
JWT_SECRET=syncbridge_production_secret_key_which_must_be_at_least_256_bits_long_2026

# [3] AI Provider Settings (Spring AI / LangChain)
# Jargon 번역 Fallback 처리를 위한 OpenAI API 키
OPENAI_API_KEY=sk-your-openai-api-key-here
